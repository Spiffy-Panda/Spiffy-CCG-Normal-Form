// =============================================================================
// Fixture: Sentinel + Fortify keyword wiring probes.
// =============================================================================
// Same two-arena / two-conduit shape as clash.ccgnf, but both players get a
// Main Phase + cards so the defender can put a Sentinel / Fortify Unit on
// the board before Player1 clashes. Used by KeywordWiringTests.

Entity Game {
  kind: Game
  characteristics: { round: 1, first_player: Unbound }
  abilities: []
}

Entity Player[i] for i ∈ {1, 2} {
  kind: Player
  characteristics: { integrity_start: 7 }
  counters: { aether: 10, debt: 0 }
  zones: {
    Arsenal:     Zone(order: sequential),
    Hand:        Zone(order: unordered),
    Battlefield: Zone(order: unordered),
    Cache:       Zone(order: FIFO)
  }
  abilities: []
}

Entity Arena[pos] for pos ∈ {Left, Right} {
  kind: Arena
  characteristics: { position: pos }
}

// A vanilla attacker — Force 4, Ramparts 1, no keywords.
Card HeavyStriker {
  factions: {NEUTRAL}, type: Unit, cost: 1, force: 4, ramparts: 1, rarity: C
  abilities: []
}

// Plain Sentinel body — Force 3 / Ramparts 2. Per Keyword_Sentinel:
// projects 0 Force, adds its Force to its side's Fortification.
Card SentinelWall {
  factions: {NEUTRAL}, type: Unit, cost: 1, force: 3, ramparts: 2, rarity: C
  keywords: [ Sentinel ]
  abilities: []
}

// Fortify 2 body — Ramparts 3 base + 2 while controller's Conduit in this
// Arena is at integrity ≥ 4.
Card FortifyWall {
  factions: {NEUTRAL}, type: Unit, cost: 1, force: 2, ramparts: 3, rarity: C
  keywords: [ Fortify(2) ]
  abilities: []
}

// Triggered-on-Unit probe: a 1-drop whose only text is "when this enters
// play, set Player2.debt = 42". Uses the raw Triggered form so the probe
// exercises the dispatch path without depending on the OnEnter shorthand
// macro being in scope for this fixture.
Card DebtPinger {
  factions: {NEUTRAL}, type: Unit, cost: 1, force: 1, ramparts: 1, rarity: C
  abilities: [
    Triggered(
      on:     Event.EnterPlay(target=self),
      effect: SetCounter(Player2, debt, 42))
  ]
}

// OnEnter shorthand — the Attach-time expander should rewrite this to the
// Triggered form above. Sets Player2.debt = 7 on entry.
Card OnEnterShorthandPinger {
  factions: {NEUTRAL}, type: Unit, cost: 1, force: 1, ramparts: 1, rarity: C
  abilities: [
    OnEnter(SetCounter(Player2, debt, 7))
  ]
}

// EndOfClash shorthand — expander should rewrite to Triggered(on:
// Event.PhaseEnd(phase=Clash), ...). Sets Player2.debt = 11.
Card EndOfClashPinger {
  factions: {NEUTRAL}, type: Unit, cost: 1, force: 0, ramparts: 1, rarity: C
  abilities: [
    EndOfClash(SetCounter(Player2, debt, 11))
  ]
}

// Mend 2 keyword — KeywordRuntime should synthesise an OnEnter-shaped
// Triggered that calls HealSelfArenaConduit. Conduit must start below
// starting_integrity for the heal to be observable.
Card MendPinger {
  factions: {NEUTRAL}, type: Unit, cost: 1, force: 1, ramparts: 1, rarity: C
  keywords: [ Mend(2) ]
  abilities: []
}

// OnCardPlayed lambda-filter probe: when a NEUTRAL Maneuver is played by
// the same controller, set Player2.debt = 77. Requires the lambda filter
// expansion to inline the filter body as an If-guard in the effect.
Card LambdaPinger {
  factions: {NEUTRAL}, type: Unit, cost: 1, force: 1, ramparts: 1, rarity: C
  abilities: [
    OnCardPlayed(
      filter: c -> c.type == Maneuver,
      effect: SetCounter(Player2, debt, 77))
  ]
}

// Dummy Maneuver the LambdaPinger filters on. Doesn't need to do anything
// on resolution — just being played is enough to trigger the OnCardPlayed.
Card NoOpSpell {
  factions: {NEUTRAL}, type: Maneuver, cost: 1, rarity: C
  abilities: [ OnResolve(NoOp) ]
}

// Recur keyword probe: unit enters play with Recur, controller's conduit
// on that arena is pushed to 0 so the arena collapses, Recur replaces
// the destroy-to-Cache with destroy-to-bottom-of-Arsenal.
Card RecurUnit {
  factions: {TIDE}, type: Unit, cost: 1, force: 1, ramparts: 1, rarity: C
  keywords: [ Recur ]
  abilities: []
}

// Unique keyword probe: controller plays two copies; the second Replacement
// bounces the duplicate to Cache instead of Battlefield.
Card UniqueUnit {
  factions: {NEUTRAL}, type: Unit, cost: 1, force: 1, ramparts: 1, rarity: M, unique: true
  keywords: [ Unique ]
  abilities: []
}

// Phantom keyword probe: auto-fades at Start of Clash (projected force 0),
// returns to hand at End of Clash with cost reduced by 1.
Card PhantomUnit {
  factions: {HOLLOW}, type: Unit, cost: 2, force: 3, ramparts: 1, rarity: C
  keywords: [ Phantom ]
  abilities: []
}

// Drift keyword probe: at end of controller's turn, unit moves to an
// adjacent arena whose controller-side Conduit is alive.
Card DriftUnit {
  factions: {TIDE}, type: Unit, cost: 1, force: 1, ramparts: 1, rarity: C
  keywords: [ Drift ]
  abilities: []
}

// Sprawl keyword probe via Maneuver OnResolve. Creates 2 Sapling tokens
// in the caster's controlled arena.
Card SprawlMaker {
  factions: {THORN}, type: Maneuver, cost: 1, rarity: C
  abilities: [
    OnResolve(Sprawl(2, in: Left, for: controller))
  ]
}

// Shroud keyword probe: opponent's damage Maneuver targeting Shroud Unit
// should find zero legal targets.
Card ShroudUnit {
  factions: {HOLLOW}, type: Unit, cost: 1, force: 1, ramparts: 1, rarity: C
  keywords: [ Shroud ]
  abilities: []
}

// Opponent's targeting Maneuver that tries to DealDamage to any Unit.
Card TargetedStrike {
  factions: {NEUTRAL}, type: Maneuver, cost: 1, rarity: C
  abilities: [
    OnResolve(Target(u -> u.type == Unit, DealDamage(target, 1)))
  ]
}

// Setup: conduits per (owner, arena), both players draw, both get a Main
// Phase so either side can commit a Unit to the board. Player1 then drives
// a single Clash pass.
Game.abilities += Triggered(
  on:     Event.GameStart,
  effect: Sequence([
    InstantiateEntity(kind: Conduit, owner: Player1, arena: Left,  initial_counters: { integrity: 7 }),
    InstantiateEntity(kind: Conduit, owner: Player1, arena: Right, initial_counters: { integrity: 7 }),
    InstantiateEntity(kind: Conduit, owner: Player2, arena: Left,  initial_counters: { integrity: 7 }),
    InstantiateEntity(kind: Conduit, owner: Player2, arena: Right, initial_counters: { integrity: 7 }),
    Draw(Player1, amount: 1),
    Draw(Player2, amount: 1),
    EnterMainPhase(Player2),
    EnterMainPhase(Player1),
    ResolveClashPhase(active_player: Player1)
  ]))
