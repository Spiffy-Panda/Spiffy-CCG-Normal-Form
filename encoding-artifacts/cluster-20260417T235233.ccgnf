/*
 * Warden of the Mended Wall [R] (BULWARK, Unit) — 5 — 3/5
 * Mend 2.
 * BULWARK 4: When another friendly BULWARK Unit enters this Arena, Mend 1.
 *
 * A slow, Peak-adjacent engine. Enters with a single Mend; at BULWARK 4 each
 * subsequent BULWARK Unit entering the same Arena topups the Conduit by 1.
 */
Card WardenOfTheMendedWall {
  factions: {BULWARK}, type: Unit, cost: 5, force: 3, ramparts: 5, rarity: R
  keywords: [ Mend(2), DeploymentSickness ]
  abilities: [
    OnArenaEnter(
      filter: u -> u != self
                 ∧ BULWARK ∈ u.factions
                 ∧ u.type == Unit
                 ∧ u.controller == self.controller,
      effect: When(Resonance(BULWARK, 4),
        If(not collapsed_for(self.controller, self.arena),
           Heal(self.controller.Conduit(self.arena), 1, cap: starting_integrity),
           NoOp)))
  ]
  // text: Mend 2. BULWARK 4: When another friendly BULWARK Unit enters this
  //       Arena, Mend 1.
}

