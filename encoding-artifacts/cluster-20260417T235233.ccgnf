/*
 * Bramblewarden [U] (THORN/BULWARK, Unit) — 3 — 3/3
 * When this enters play, create a 1/1 Sapling in this Arena.
 *
 * Pushes both THORN and BULWARK Echoes. Body + immediate Sprawl-1 supports
 * the THORN/BULWARK Big Mid-range archetype.
 */
Card Bramblewarden {
  factions: {THORN, BULWARK}, type: Unit, cost: 3, force: 3, ramparts: 3, rarity: U
  keywords: [ DeploymentSickness ]
  abilities: [
    OnEnter(
      If(not collapsed_for(self.controller, self.arena),
         CreateToken(template:   ThornSapling,
                     zone:       self.arena,
                     owner:      self.controller,
                     controller: self.controller),
         NoOp))
  ]
  // text: When this enters play, create a 1/1 Sapling in this Arena.
  //       (Pushes both THORN and BULWARK Echoes.)
}

