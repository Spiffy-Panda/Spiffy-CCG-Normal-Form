/*
 * Bannerkeeper [U] (NEUTRAL, Unit) — 4 — 3/4
 * While your Banner exists, this has +1/+1.
 *
 * Pure Banner-scaling Neutral glue. Off Banner it's a fair 4-cost 3/4; with a
 * Banner it's a 4/5 that splashes into any committed deck.
 */
Card Bannerkeeper {
  factions: {NEUTRAL}, type: Unit, cost: 4, force: 3, ramparts: 4, rarity: U
  keywords: [ DeploymentSickness ]
  abilities: [
    Static(
      modifies: Characteristic(self, {force, ramparts}, layer: 2),
      check_at: continuously,
      rule: If(BannerExists(),
        Sequence([
          AddToCharacteristic(self, force,    1),
          AddToCharacteristic(self, ramparts, 1)
        ]),
        NoOp))
  ]
  // text: While your Banner exists, this has +1/+1.
}

/*
 * Thornwall Bastion [C] (THORN/BULWARK dual, Standard — attaches to Arena) — 3
 * Your Units in this Arena have Fortify 1.
 *
 * A splashable common Standard that rewards committing bodies to one Arena.
 * The Fortify suppression rule still applies — a below-4 Conduit in this
 * Arena disables the bonus.
 */
Card ThornwallBastion {
  factions: {THORN, BULWARK}, type: Standard, subtype: attaches_to_arena, cost: 3, rarity: C
  abilities: [
    Static(
      modifies: KeywordSet(unit),
      check_at: continuously,
      rule: ForEach(u -> u.controller == self.controller
                       ∧ u.type == Unit
                       ∧ u.arena == self.arena,
              GrantKeyword(u, Fortify(1))))
  ]
  // text: Your Units in this Arena have Fortify 1.
  //       (Pushes both THORN and BULWARK Echoes.)
}
