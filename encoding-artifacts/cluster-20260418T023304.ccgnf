  factions: {NEUTRAL}, type: Maneuver, cost: 4, rarity: R
  abilities: [
    OnResolve(
      Target(t -> t.kind ∈ {Unit, Conduit},
        If(BannerExists(),
           DealDamage(target, 6),
           DealDamage(target, 4))))
  ]
  // text: Deal 4 damage. If your Banner exists, deal 6 instead.
}
