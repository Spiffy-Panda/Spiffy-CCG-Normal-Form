}

/*
 * Searing Wave [C] (EMBER, Maneuver) — 4
 * Deal 2 damage to each opposing Unit in target Arena.
 * EMBER 4: Also deal 2 to the opposing Conduit there.
 */
Card SearingWave {
  factions: {EMBER}, type: Maneuver, cost: 4, rarity: C
  abilities: [
    OnResolve(
      Target(a -> a.kind == Arena,
        Sequence([
          ForEach(u -> u.arena == target
                     ∧ u.controller != self.controller
                     ∧ u.type == Unit,
            DealDamage(u, 2)),
          When(Resonance(EMBER, 4),
            If(Exists(Conduit[other_player(self.controller), target])
               ∧ not collapsed_for(other_player(self.controller), target),
               DealDamage(Conduit[other_player(self.controller), target], 2),
               NoOp))
        ])))
  ]
  // text: Deal 2 to each opposing Unit in target Arena.
  //       EMBER 4: Also deal 2 to the opposing Conduit there.
}

