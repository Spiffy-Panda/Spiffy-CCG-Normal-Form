 */
Card Whisperthief {
  factions: {HOLLOW}, type: Maneuver, cost: 2, rarity: C
  abilities: [
    OnResolve(
      Tiers([
        (Resonance(HOLLOW, 3), Pilfer(2)),
        (Default,              Pilfer(1))
      ]))
  ]
  // text: Pilfer 1. HOLLOW 3: Pilfer 2 instead.
}

/*
 * Veiled Strike [C] (HOLLOW, Maneuver) — 2
 * Deal 2 damage to a Unit.
 * HOLLOW 3: That Unit also gets -1/-0 until end of turn.
 */
Card VeiledStrike {
  factions: {HOLLOW}, type: Maneuver, cost: 2, rarity: C
  abilities: [
    OnResolve(
      Target(u -> u.type == Unit,
        Sequence([
          DealDamage(target, 2),
          When(Resonance(HOLLOW, 3),
            ModifyCharacteristic(target, force, -1, duration: end_of_turn, layer: 2))
        ])))
  ]
  // text: Deal 2 to a Unit. HOLLOW 3: That Unit gets -1/-0 until end of turn.
}

