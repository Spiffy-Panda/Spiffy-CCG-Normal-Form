/*
 * Drifting Mist [U] (TIDE, Maneuver) — 3
 * Each of your Drift Units may Drift now (per-Unit choice).
 */
Card DriftingMist {
  factions: {TIDE}, type: Maneuver, cost: 3, rarity: U
  abilities: [
    OnResolve(
      ForEach(u -> u.controller == self.controller
                 ∧ u.type == Unit
                 ∧ Drift ∈ u.keywords,
        Choice(self.controller, {
          pass:  NoOp,
          drift: Target(a -> a ∈ adjacent(u.arena)
                            ∧ not collapsed_for(u.controller, a),
                        MoveUnitToArena(u, a))
        })))
  ]
  // text: Each of your Drift Units may Drift now.
}

