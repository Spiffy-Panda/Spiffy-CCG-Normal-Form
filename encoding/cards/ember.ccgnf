/*
 * Match Strike [C] (EMBER, Maneuver) — 1
 * Deal 1 damage to a Unit or Conduit.
 * EMBER 2: Deal 2 instead.
 */
Card MatchStrike {
  factions: {EMBER}, type: Maneuver, cost: 1, rarity: C
  abilities: [
    OnResolve(
      Target(t -> t.kind ∈ {Unit, Conduit},
        Tiers([
          (Resonance(EMBER, 2), DealDamage(target, 2)),
          (Default,             DealDamage(target, 1))
        ])))
  ]
  // text: Deal 1 damage to a Unit or Conduit. EMBER 2: Deal 2 instead.
}

/*
 * Pyrearrow [C] (EMBER, Maneuver) — 2
 * Deal 1 damage to each opposing Unit and the opposing Conduit in target Arena.
 * EMBER 3: Deal 2 instead.
 */
Card Pyrearrow {
  factions: {EMBER}, type: Maneuver, cost: 2, rarity: C
  abilities: [
    OnResolve(
      Target(a -> a.kind == Arena,
        Tiers([
          (Resonance(EMBER, 3),
            ForEach(t -> t.arena == target
                       ∧ t.controller != self.controller
                       ∧ (t.type == Unit ∨ t.kind == Conduit),
              DealDamage(t, 2))),
          (Default,
            ForEach(t -> t.arena == target
                       ∧ t.controller != self.controller
                       ∧ (t.type == Unit ∨ t.kind == Conduit),
              DealDamage(t, 1)))
        ])))
  ]
  // text: Deal 1 damage to each opposing Unit and Conduit in target Arena.
  //       EMBER 3: Deal 2 instead.
}

/*
 * Searing Wave [C] (EMBER, Maneuver) — 4
 * Deal 2 damage to each opposing Unit in target Arena.
 * EMBER 4: Also deal 2 to the opposing Conduit there.
 */
Card SearingWave {
  factions: {EMBER}, type: Maneuver, cost: 4, rarity: C
  abilities: [
    OnResolve(
      Target(a -> a.kind == Arena,
        Sequence([
          ForEach(u -> u.arena == target
                     ∧ u.controller != self.controller
                     ∧ u.type == Unit,
            DealDamage(u, 2)),
          When(Resonance(EMBER, 4),
            If(Exists(Conduit[other_player(self.controller), target])
               ∧ not collapsed_for(other_player(self.controller), target),
               DealDamage(Conduit[other_player(self.controller), target], 2),
               NoOp))
        ])))
  ]
  // text: Deal 2 to each opposing Unit in target Arena.
  //       EMBER 4: Also deal 2 to the opposing Conduit there.
}

