/*
 * Sunfire Marshal [R] (EMBER, Unit) — 5 — 5/4
 * Surge. When this enters play, deal 2 damage to the opposing Conduit in this Arena.
 */
Card SunfireMarshal {
  factions: {EMBER}, type: Unit, cost: 5, force: 5, ramparts: 4, rarity: R
  keywords: [ Surge, DeploymentSickness ]
  abilities: [
    OnEnter(
      If(Exists(Conduit[other_player(self.controller), self.arena])
         ∧ not collapsed_for(other_player(self.controller), self.arena),
         DealDamage(Conduit[other_player(self.controller), self.arena], 2),
         NoOp))
  ]
  // text: Surge. When this enters play, deal 2 to the opposing Conduit in this Arena.
}

/*
 * Roaring Champion [R] (EMBER, Unit) — 5 — 6/3
 * Surge. Friendly EMBER Units in this Arena have +1/+0.
 */
Card RoaringChampion {
  factions: {EMBER}, type: Unit, cost: 5, force: 6, ramparts: 3, rarity: R
  keywords: [ Surge, DeploymentSickness ]
  abilities: [
    Static(
      modifies: Characteristic(target_unit, force, layer: 2),
      check_at: continuously,
      rule: ForEach(u -> u.arena == self.arena
                       ∧ u.controller == self.controller
                       ∧ u.type == Unit
                       ∧ EMBER ∈ u.factions
                       ∧ u != self,
        AddToCharacteristic(u, force, 1)))
  ]
  // text: Surge. Friendly EMBER Units in this Arena have +1/+0.
}
