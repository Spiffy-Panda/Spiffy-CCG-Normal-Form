  factions: {EMBER}, type: Maneuver, cost: 3, rarity: R
  abilities: [
    OnResolve(
      ForEach(u -> u.controller == self.controller ∧ u.type == Unit,
        GrantKeyword(u, Blitz, duration: end_of_turn)))
  ]
  // text: Friendly Units gain Blitz this turn.
}

